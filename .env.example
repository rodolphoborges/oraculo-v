# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados (Oráculo V - Interno)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Banco de Dados (Protocolo V - Integração)
PROTOCOL_SUPABASE_URL=https://protocol-v-id.supabase.co
PROTOCOL_SUPABASE_KEY=protocol-v-key

# Autenticação (JWT e API Key)
JWT_SECRET=super-secret-key-change-me
JWT_EXPIRATION=7d
ADMIN_API_KEY=your-secure-admin-api-key-here

# Notificações e Integrações Externas
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRstuVWxYz
RIOT_API_KEY=RGAPI-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# INTEGRALIDADES EXTERNAS (OPCIONAIS)
# HENRIK_API_KEY=your_henrik_api_key_v3 (Necessário apenas para radar-legacy)

# Configurações de Cache e Arquivos
ANALYSIS_CACHE_DAYS=30
GITHUB_ACTIONS=false
